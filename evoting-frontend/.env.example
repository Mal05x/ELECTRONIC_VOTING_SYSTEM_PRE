# ─────────────────────────────────────────────────────────
#  eVoting Frontend — Environment Variables
#  Copy this file to .env.local for local development
#  Set these in your Vercel project settings for production
# ─────────────────────────────────────────────────────────

# Base URL of the Spring Boot backend (evoting-backend-v4)
# No trailing slash.
# Local dev:    https://localhost:8443
# Production:   https://your-backend.railway.app  (or any host)
VITE_API_URL=https://localhost:8443

# WebSocket base URL (usually same as API URL)
VITE_WS_URL=https://localhost:8443

# Set to "true" to run the app with mock data (no backend required)
# Useful for Vercel preview deployments before the backend is ready
VITE_DEMO_MODE=false
